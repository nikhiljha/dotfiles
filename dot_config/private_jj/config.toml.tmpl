#:schema https://jj-vcs.github.io/jj/latest/config-schema.json

[user]
name = "Nikhil Jha"
email = "{{ .email | default "nikhiljha@users.noreply.github.com" }}"

[aliases]
spr = ["util", "exec", "--", "jj-spr"]

[spr]
requireTestPlan = false

[template-aliases]
'format_short_change_id(id)' = 'id.shortest(4)'
'format_short_commit_id(id)' = 'id.shortest(4)'
prompt = '''
separate(" ",
  format_short_change_id(change_id) ++ if(hidden, label("hidden", "†"), "") ++ if(divergent, label("divergent", "??"), ""),
  format_short_commit_id(commit_id),
  if(empty, label("empty", "e"), ""),
  if(description == "", label("description placeholder", "d"), ""),
  if(description.starts_with("wip"), label("wip", "(wip)"), ""),
  if(description.starts_with("todo"), label("todo", "(todo)"), ""),
  if(description.starts_with("vibe"), label("vibe", "(vibe)"), ""),
  if(conflict, label("conflict", "(conflict)"), "")
)
'''

[revset-aliases]
'closest_bookmark(to)' = 'heads(::to & bookmarks())'
'local()' = 'mine() & (trunk()..@)::'

[colors]
wip = "yellow"
todo = "blue"
vibe = "cyan"
mega = "red"

[ui]
# default-command = ["log", "-r", "ancestors(((heads(::@ & ::trunk())+ ~ trunk()):: & mutable()), 2) | trunk()"]
default-command = ["log"]